# Production URLs:
#   Backend:  https://ai-interview-backend-production-e046.up.railway.app
#   Frontend: https://a-i-interview-frontend.vercel.app
#
# Copy to .env for local runs, or paste .env.railway into Railway → Variables.
# Never commit real secrets — .env and .env.railway are gitignored.

NODE_ENV=production
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Railway Postgres plugin injects DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer

# LLM (required on Railway — Ollama is not available)
# LLM — ollama (local/Railway Ollama service) or openrouter (cloud)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Frontend (join links, emails, Socket.io CORS)
FRONTEND_URL=https://a-i-interview-frontend.vercel.app

# Admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Speech-to-text (multilingual: en, ur, ar, fr, de, hi, es, …)
# local = whisper.cpp in Docker (default on Railway)
# speaches = Railway Speaches service (OpenAI-compatible, faster on CPU)
# openai = OpenAI Whisper API
STT_PROVIDER=local
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/app/models/ggml-base.bin
# auto = detect language | or fixed: en, ur, ar, fr, de, hi, es
WHISPER_LANGUAGE=auto

# Multilingual cloud TTS (Urdu, Arabic, English, …) — Microsoft Edge neural, no API key
TTS_PROVIDER=edge

# Optional: OpenAI TTS instead (requires OPENAI_API_KEY)
# TTS_PROVIDER=openai

# Multilingual cloud TTS — Edge neural rate (+30% = faster; +0% = normal)
EDGE_TTS_RATE=+30%

# Default interview language for new schedules (recruiter profile; optional on Railway)
# DEFAULT_INTERVIEW_LANGUAGE is stored per user in DB after bootstrap

# Speaches on Railway (when STT_PROVIDER=speaches)
# SPEACHES_BASE_URL=https://your-speaches.up.railway.app
# SPEACHES_API_KEY=your-speaches-api-key
# SPEACHES_MODEL=Systran/faster-distil-whisper-small.en

# Optional: Redis plugin for session persistence
# REDIS_URL=memory

# Email — Resend (recommended for Railway) or SMTP fallback
# Resend: https://resend.com — use onboarding@resend.dev for testing
MAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=Intervion <onboarding@resend.dev>
MAIL_REPLY_TO=
CONTACT_NOTIFY_EMAIL=
# Resend inbound webhook secret (Dashboard → Webhooks → email.received)
# Webhook URL: https://your-backend.up.railway.app/api/v1/public/resend/webhook
RESEND_WEBHOOK_SECRET=

# SMTP fallback (Gmail, SendGrid SMTP, etc.)
# MAIL_SERVICE=gmail
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=
