# Production URLs:
#   Backend:  https://ai-interview-backend-production-e046.up.railway.app
#   Frontend: https://a-i-interview-frontend.vercel.app
#
# Copy to .env for local runs, or paste .env.railway into Railway → Variables.
# Never commit real secrets — .env and .env.railway are gitignored.

NODE_ENV=production
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Railway Postgres plugin injects DATABASE_URL automatically
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer

# LLM (required on Railway — Ollama is not available)
# LLM — ollama (local/Railway Ollama service) or openrouter (cloud)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Frontend (join links, emails, Socket.io CORS)
FRONTEND_URL=https://a-i-interview-frontend.vercel.app

# Admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Speech-to-text
# local = whisper.cpp in Docker (default)
# speaches = Railway Speaches service (OpenAI-compatible, recommended)
# openai = OpenAI Whisper API
STT_PROVIDER=local
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/app/models/ggml-base.en.bin

# Speaches on Railway (when STT_PROVIDER=speaches)
# SPEACHES_BASE_URL=https://your-speaches.up.railway.app
# SPEACHES_API_KEY=your-speaches-api-key
# SPEACHES_MODEL=Systran/faster-distil-whisper-small.en

# Optional: Redis plugin for session persistence
# REDIS_URL=memory

# Optional: email for interview invites
# MAIL_SERVICE=gmail
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=
