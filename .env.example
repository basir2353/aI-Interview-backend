# Server
NODE_ENV=production
# Railway sets PORT automatically — do not hardcode in production
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1

# JWT (required – use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# PostgreSQL – Railway: add Postgres plugin; it injects DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer

# Redis (optional). Omit or set to "memory" for in-memory sessions.
# Railway: add Redis plugin and use the injected REDIS_URL
# REDIS_URL=memory

# LLM – Open Router (recommended for Railway; no local Ollama needed)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Ollama (local only – not used on Railway when OPENROUTER_API_KEY is set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Speech-to-text
# local = whisper.cpp (included in Dockerfile) | openai = OpenAI Whisper API (lighter image)
STT_PROVIDER=local
WHISPER_CPP_PATH=/usr/local/bin/whisper-cli
WHISPER_MODEL_PATH=/app/models/ggml-base.en.bin
WHISPER_MODEL=base.en
WHISPER_LANGUAGE=en
# OPENAI_API_KEY=   # required when STT_PROVIDER=openai

# Frontend URL (your deployed Next.js app – no trailing slash)
FRONTEND_URL=https://your-frontend.up.railway.app

# Admin panel
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Mail (optional – for interview schedule emails)
# MAIL_SERVICE=gmail
# MAIL_USER=
# MAIL_PASS=
# MAIL_FROM=

# WebRTC
WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302

# Interview limits
INTERVIEW_MAX_DURATION=1800
INTERVIEW_MAX_SILENCE=30
INTERVIEW_MIN_QUESTIONS=5
INTERVIEW_MAX_QUESTIONS=15
